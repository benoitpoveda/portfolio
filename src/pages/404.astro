---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---

<BaseLayout title={`404 — ${site.name}`} description="Page introuvable." path="/404">
  <main class="nf">
    <div class="nf-inner">
      <p class="nf-label">// ERREUR 404</p>
      <div class="nf-code">404</div>
      <p class="nf-text">Cette planche n'existe pas (ou plus).</p>
      <div class="nf-cta">
        <a class="nf-btn nf-btn--solid" href={site.routes.portail}>← Portail</a>
        <a class="nf-btn" href={site.routes.portfolio}>→ Portfolio</a>
        <a class="nf-btn" href={site.routes.cv}>↓ CV</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .nf {
    min-height: 100vh;
    min-height: 100svh;
    display: grid;
    place-items: center;
    padding: 40px 26px;
    background:
      radial-gradient(circle, rgba(31, 94, 166, 0.1) 1px, transparent 1.4px) 0 0 / 22px 22px,
      var(--c-paper);
  }
  .nf-inner {
    text-align: center;
    max-width: 540px;
  }
  .nf-label {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-cyanotype);
    margin-bottom: 8px;
  }
  .nf-code {
    font-weight: 900;
    font-size: clamp(96px, 22vw, 200px);
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: var(--c-ink);
  }
  .nf-text {
    font-size: 17px;
    color: var(--c-text);
    margin: 10px 0 30px;
  }
  .nf-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 11px;
    justify-content: center;
  }
  .nf-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 12px 18px;
    border-radius: var(--r-sm);
    border: 1.5px solid var(--c-cyanotype);
    color: var(--c-cyanotype);
    text-decoration: none;
    transition: background 0.18s ease, color 0.18s ease;
  }
  .nf-btn:hover {
    background: var(--c-cyanotype);
    color: var(--c-surface);
    text-decoration: none;
  }
  .nf-btn--solid {
    background: var(--c-cyanotype);
    color: var(--c-surface);
  }
  .nf-btn--solid:hover {
    background: var(--c-ink);
    border-color: var(--c-ink);
  }
</style>
