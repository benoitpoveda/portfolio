---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
import { profil, parcours, labo, stack, contact } from '../data/content';

/** Enveloppe une sous-chaine dans le surlignage signature turquoise (UN seul par ecran). */
function mark(text: string, phrase: string): string {
  return text.includes(phrase)
    ? text.replace(phrase, `<span class="po-mark">${phrase}</span>`)
    : text;
}
/** Met une sous-chaine en gras (encre). */
function strong(text: string, phrase: string): string {
  return text.includes(phrase) ? text.replace(phrase, `<strong>${phrase}</strong>`) : text;
}

/* Numero + intitule (cohelper avec META cote script) — utilises pour les satellites & le menu. */
const SAT_META = [
  { id: 'profil', num: '01', label: '// PROFIL' },
  { id: 'parcours', num: '02', label: '// PARCOURS' },
  { id: 'labo', num: '03', label: '// LABO' },
  { id: 'stack', num: '04', label: '// STACK' },
  { id: 'contact', num: '05', label: '// CONTACT' },
];

const cvHref = site.routes.cv;
const cvPdfHref = site.routes.cvPdf;
const portfolioHref = site.routes.portfolio;
---

<BaseLayout
  title={site.meta.title}
  description={site.meta.description}
  path="/"
  bodyClass="po-body"
>
  <div class="po-root" data-portal-root>
    <!-- ============ FOND À DISTORSION TEMPORELLE ============
         Le canvas melt (degrade bleu + filigrane « BENOIT POVEDA ») est injecte
         ici en JS, en fond (z-index 0), et se deforme autour du curseur. Le globe
         et la nav restent nets au-dessus (.po-stage z-index 5+). Voir portal-melt.ts. -->

    <!-- ============ STAGE (globe + satellites) ============ -->
    <div class="po-stage" data-portal-stage>
      <canvas class="po-canvas" aria-hidden="true" data-portal-canvas></canvas>

      {SAT_META.map((s) => (
        <button
          class="po-sat"
          type="button"
          data-sat={s.id}
          aria-label={`Ouvrir la section ${s.label.replace('// ', '')}`}
        >
          <span class="po-sat-glyph">
            <svg viewBox="0 0 72 72" aria-hidden="true">
              <g class="po-sat-ring-spin">
                <circle cx="36" cy="36" r="21"></circle>
                <ellipse cx="36" cy="36" rx="28" ry="8" transform="rotate(-24 36 36)"></ellipse>
                <ellipse cx="36" cy="36" rx="28" ry="8" transform="rotate(35 36 36)"></ellipse>
              </g>
              <path class="po-sat-cross" d="M36 10v11M36 51v11M10 36h11M51 36h11"></path>
              <circle class="po-sat-soft" cx="36" cy="36" r="10"></circle>
              <circle class="po-sat-mint-fill" cx="36" cy="36" r="5.2"></circle>
            </svg>
          </span>
          <span class="po-sat-leader" data-sat-leader aria-hidden="true"></span>
          <span class="po-sat-node" data-sat-node aria-hidden="true"></span>
          <span class="po-sat-label" data-sat-label>{s.label}</span>
        </button>
      ))}
    </div>

    <!-- ============ HEADER ============ -->
    <header class="po-header">
      <div class="po-actions">
        <a class="po-link-read" href={portfolioHref}>Vue lecture / classique →</a>
        <button class="po-menu-btn" type="button" data-menu-toggle aria-label="Ouvrir le menu des sections">
          // Menu
        </button>
        <a class="po-cv-btn" href={cvPdfHref} download>Télécharger le CV →</a>
      </div>
    </header>

    <!-- ============ INDICE 1er chargement ============ -->
    <div class="po-hint" data-hint>→ Cliquez sur un satellite · ou ouvrez le menu</div>

    <!-- ============ IDENTITÉ ============ -->
    <div class="po-identity">
      <h1 class="po-name">{site.name}</h1>
      <div class="po-subtitle">{site.shortRole}</div>
      <div class="po-status">
        DISPO&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;// {site.status.dispo}<br />
        OBJECTIF&nbsp;&nbsp;// {site.status.focus}
      </div>
    </div>

    <div class="po-coords">
      LAT 43.70°N · LON 7.27°E<br />// RELEVÉ ORBITAL · {site.location}
    </div>

    <!-- ============ MENU DE REPLI ============ -->
    <div class="po-menu" data-menu hidden>
      <div class="po-menu-card" role="menu" aria-label="Sections du portfolio">
        <div class="po-menu-head">
          <span class="po-menu-title">// SECTIONS</span>
          <button class="po-menu-x" type="button" data-menu-close aria-label="Fermer le menu">✕</button>
        </div>
        <div class="po-menu-list">
          {SAT_META.map((s) => (
            <button class="po-menu-item" type="button" data-menu-item={s.id}>
              <span class="po-menu-num">{s.num}</span>
              <span class="po-menu-sq"></span>
              <span class="po-menu-label">{s.label}</span>
              <span class="po-menu-arrow">→</span>
            </button>
          ))}
          <a class="po-menu-read" href={portfolioHref} data-menu-cv>
            <span class="po-menu-read-label">↳ VUE LECTURE / CLASSIQUE</span>
            <span class="po-menu-read-arrow">→</span>
          </a>
          <a class="po-menu-cv" href={cvPdfHref} download data-menu-cv>
            <span class="po-menu-cv-label">↓ TÉLÉCHARGER LE CV (PDF)</span>
            <span class="po-menu-cv-arrow">→</span>
          </a>
        </div>
      </div>
    </div>

    <!-- ============ MODALE ============ -->
    <div class="po-modal" data-modal hidden>
      <div class="po-modal-card" role="dialog" aria-modal="true" data-modal-card data-modal-arialabel>
        <span class="po-corner po-corner--tl" aria-hidden="true"></span>
        <span class="po-corner po-corner--tr" aria-hidden="true"></span>
        <span class="po-corner po-corner--bl" aria-hidden="true"></span>
        <span class="po-corner po-corner--br" aria-hidden="true"></span>

        <div class="po-strip" aria-hidden="true">
          <span class="po-strip-top">DOSSIER · B.POVEDA</span>
          <span class="po-strip-bottom">RELEVÉ ORBITAL · NICE</span>
        </div>

        <div class="po-modal-main">
          <div class="po-modal-head">
            <div>
              <div class="po-modal-section">SECTION <span data-modal-num></span> / 05</div>
              <h2 class="po-modal-title" data-modal-title></h2>
              <div class="po-modal-desc" data-modal-desc></div>
            </div>
            <button class="po-modal-x" type="button" data-modal-close aria-label="Fermer">✕</button>
          </div>

          <div class="po-modal-body">
            <!-- PROFIL -->
            <div data-section-body="profil" hidden>
              <h2 class="po-profil-h">Je n'attends pas qu'un outil existe pour gagner du temps.</h2>
              <p class="po-p" set:html={strong(profil.paragraphs[0], 'je le construis')}></p>
              <p class="po-p" set:html={mark(profil.paragraphs[1], '~150 h économisées sur 230 articles')}></p>
              <p class="po-p">{profil.paragraphs[2]}</p>
              <p class="po-p">{profil.paragraphs[3]}</p>
              <p class="po-p po-p--last">{profil.paragraphs[4]}</p>
            </div>

            <!-- PARCOURS -->
            <div data-section-body="parcours" hidden>
              <div class="po-jobs">
                {parcours.jobs.map((job, i) => (
                  <div class={`po-job${i === 0 ? ' is-active' : ''}`}>
                    <div class="po-job-top">
                      <h3 class="po-job-role">{job.role}</h3>
                      <span class={`po-job-period${i === 0 ? ' is-active' : ''}`}>{job.period.toUpperCase()}</span>
                    </div>
                    <div class="po-job-org">{job.org} · {job.meta}</div>
                    {job.bullets.length > 1 ? (
                      <ul class="po-job-bullets">
                        {job.bullets.map((b) => (
                          <li class="po-job-bullet">
                            <span class="po-job-sq"></span>
                            <span set:html={strong(b, '~150 h économisées sur la refonte (230 articles)')}></span>
                          </li>
                        ))}
                      </ul>
                    ) : job.bullets.length === 1 ? (
                      <p class="po-job-text">{job.bullets[0]}</p>
                    ) : null}
                  </div>
                ))}
                <div class="po-formation">FORMATION // {parcours.formation}</div>
              </div>
            </div>

            <!-- LABO -->
            <div data-section-body="labo" hidden>
              <p class="po-labo-intro">{labo.intro}</p>
              <div class="po-cards">
                {labo.cards.map((card) => (
                  <div class="po-card">
                    <div class="po-card-cat">{card.cat}</div>
                    <h4 class="po-card-title">{card.title}</h4>
                    <p class="po-card-desc">{card.desc}</p>
                    <div class="po-card-meta">
                      <div><span class="po-card-k">STACK //</span> {card.stack}</div>
                      <div><span class="po-card-k">PREUVE //</span> {card.preuve}</div>
                      {card.nodes && (
                        <div><span class="po-card-k">NODES //</span> {card.nodes}</div>
                      )}
                      {card.doc && (
                        <div>
                          <span class="po-card-k">DOC //</span>{' '}
                          <a class="po-card-link" href={card.doc.href} target="_blank" rel="noopener">
                            {card.doc.label} →
                          </a>
                        </div>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- STACK -->
            <div data-section-body="stack" hidden>
              <div class="po-stack">
                {stack.groups.map((g) => (
                  <div class="po-stack-row">
                    <div class="po-stack-cat">{g.name.toUpperCase()}</div>
                    <div class="po-stack-items">{g.items.join(' · ')}</div>
                  </div>
                ))}
                <div class="po-stack-row po-stack-row--last">
                  <div class="po-stack-cat po-stack-cat--enc">{stack.enCours.name.toUpperCase()}</div>
                  <div class="po-stack-items">
                    <span class="po-mark">{stack.enCours.items.join(', ')}</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- CONTACT -->
            <div data-section-body="contact" hidden>
              <h2 class="po-contact-h">Prenons contact</h2>
              <p class="po-contact-p">{contact.accroche}</p>
              <div class="po-contact-grid">
                <a class="po-contact-link" href={`mailto:${site.email}`}>
                  <span class="po-contact-k">→ EMAIL</span><span class="po-contact-v">{site.email}</span>
                </a>
                <a class="po-contact-link" href={site.links.linkedin} target="_blank" rel="noopener">
                  <span class="po-contact-k">→ LINKEDIN</span><span class="po-contact-v">{site.links.linkedinLabel}</span>
                </a>
                <a class="po-contact-link" href={site.links.github} target="_blank" rel="noopener">
                  <span class="po-contact-k">→ GITHUB</span><span class="po-contact-v">{site.links.githubLabel}</span>
                </a>
                {site.showPhoneOnSite && (
                  <a class="po-contact-link" href={`tel:${site.phone.replace(/\s+/g, '')}`}>
                    <span class="po-contact-k">→ TÉLÉPHONE</span><span class="po-contact-v">{site.phone}</span>
                  </a>
                )}
                <a class="po-contact-link po-contact-link--cv" href={cvHref}>
                  <span class="po-contact-k">→ CV</span><span class="po-contact-v po-contact-v--cv">Voir en ligne</span>
                </a>
              </div>
            </div>
          </div>

          <div class="po-modal-foot">
            <span>PLANCHE <span data-modal-num></span> / 05 · B.POVEDA</span>
            <span>43.70°N · 7.27°E · NICE, FR</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { initPortail } from '../scripts/portail';
    import { initPortalMelt } from '../scripts/portal-melt';
    initPortalMelt();
    initPortail();
  </script>
</BaseLayout>

<style>
  /* ============================================================
     PORTAIL ORBITAL — styles dedies (porte fidelement du prototype).
     Palette Portail dans tokens.css ; nuances specifiques en local.
     ============================================================ */

  /* Le Portail est un plein-ecran fixe : on neutralise le scroll du body
     et on pose le degrade bleu electrique de fond. */
  :global(body.po-body) {
    background: var(--c-portal-1);
    overflow: hidden;
  }
  :global(html:has(body.po-body)) {
    overflow: hidden;
  }

  .po-root {
    position: fixed;
    inset: 0;
    color: var(--c-on-portal);
    font-family: var(--font-sans);
    overflow: hidden;
    isolation: isolate;
    background:
      radial-gradient(circle at 48% 42%, rgba(238, 243, 255, 0.105), transparent 28%),
      radial-gradient(circle at 75% 18%, rgba(170, 210, 202, 0.09), transparent 24%),
      radial-gradient(circle at 20% 86%, rgba(238, 243, 255, 0.06), transparent 30%),
      var(--grad-portal);
  }
  .po-root ::selection {
    background: var(--c-turquoise);
    color: #11161c;
  }
  .po-root::before {
    content: '';
    position: absolute;
    inset: -20%;
    z-index: 1;
    pointer-events: none;
    opacity: 0.2;
    mix-blend-mode: screen;
    background-image:
      repeating-linear-gradient(0deg, rgba(238, 243, 255, 0.28) 0 1px, transparent 1px 5px),
      repeating-linear-gradient(24deg, rgba(238, 243, 255, 0.18) 0 1px, transparent 1px 29px),
      radial-gradient(circle at center, rgba(238, 243, 255, 0.18), transparent 58%);
    transform: rotate(-0.6deg);
  }
  .po-root::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      radial-gradient(circle at 50% 42%, transparent 0 32%, rgba(5, 10, 90, 0.18) 68%, rgba(4, 7, 64, 0.38) 100%),
      linear-gradient(90deg, rgba(238, 243, 255, 0.05), transparent 18%, transparent 82%, rgba(238, 243, 255, 0.035));
  }

  /* ---------- STAGE / CANVAS / SATELLITES ---------- */
  .po-stage {
    position: absolute;
    inset: 0;
    z-index: 5;
  }
  .po-canvas {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
  }

  .po-sat {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 54px;
    height: 54px;
    display: grid;
    place-items: center;
    background: none;
    border: 0;
    cursor: pointer;
    color: var(--c-on-portal);
    z-index: 16;
    transition: color 0.22s ease, filter 0.22s ease;
    border-radius: 999px;
    isolation: isolate;
  }
  .po-sat::before {
    content: '';
    position: absolute;
    inset: 7px;
    border-radius: 999px;
    background: rgba(170, 210, 202, 0.05);
    border: 1px solid rgba(238, 243, 255, 0.16);
    opacity: 0;
    transform: scale(0.84);
    transition: opacity 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
  }
  .po-sat:hover::before,
  .po-sat:focus-visible::before {
    opacity: 1;
    transform: scale(1);
    box-shadow: 0 0 28px rgba(170, 210, 202, 0.24);
  }
  .po-sat:focus-visible {
    outline: none;
  }
  .po-sat-glyph {
    display: grid;
    place-items: center;
    transition: color 0.22s ease;
    filter: drop-shadow(0 0 7px rgba(7, 12, 110, 0.86));
  }
  .po-sat-glyph svg {
    width: 42px;
    height: 42px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.35;
    stroke-linecap: round;
    stroke-linejoin: round;
    overflow: visible;
  }
  .po-sat-ring-spin {
    transform-origin: 36px 36px;
    animation: po-satspin 18s linear infinite;
  }
  .po-sat-mint-fill {
    fill: var(--c-turquoise);
    stroke: none;
    filter: drop-shadow(0 0 6px rgba(170, 210, 202, 0.45));
  }
  .po-sat-soft {
    opacity: 0.44;
  }
  .po-sat-cross {
    opacity: 0.72;
  }
  .po-sat:hover .po-sat-glyph,
  .po-sat:focus-visible .po-sat-glyph {
    color: #ddf7f0;
    filter: drop-shadow(0 0 10px rgba(170, 210, 202, 0.46)) drop-shadow(0 0 20px rgba(238, 243, 255, 0.18)) !important;
  }
  .po-sat:hover .po-sat-ring-spin,
  .po-sat:focus-visible .po-sat-ring-spin {
    animation-duration: 9s;
  }
  .po-sat-leader {
    position: absolute;
    left: calc(50% + 20px);
    top: 50%;
    height: 1px;
    width: 38px;
    transform: translateY(-50%);
    transform-origin: left center;
    background: linear-gradient(90deg, rgba(170, 210, 202, 0.92), rgba(170, 210, 202, 0.28));
    opacity: 0.62;
    transition: opacity 0.2s ease, background 0.2s ease;
    pointer-events: none;
  }
  .po-sat-node {
    position: absolute;
    left: calc(50% + 20px);
    top: 50%;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--c-turquoise);
    transform: translate(-50%, -50%);
    opacity: 0.76;
    transition: opacity 0.2s ease;
    pointer-events: none;
    box-shadow: 0 0 12px rgba(170, 210, 202, 0.42);
  }
  .po-sat-label {
    position: absolute;
    left: calc(50% + 62px);
    top: 50%;
    transform: translateY(-50%);
    white-space: nowrap;
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.13em;
    color: rgba(170, 210, 202, 0.82);
    opacity: 0.82;
    transition: opacity 0.2s ease, color 0.2s ease;
    pointer-events: none;
    text-shadow: 0 0 14px rgba(7, 12, 110, 0.9);
  }
  .po-sat:hover .po-sat-label,
  .po-sat:focus-visible .po-sat-label {
    opacity: 1 !important;
    color: #d7f2ec !important;
  }

  /* ---------- HEADER ---------- */
  .po-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 40;
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    gap: 16px;
    padding: 22px 26px;
  }
  .po-badge {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.13em;
    color: rgba(238, 243, 255, 0.84);
    display: flex;
    align-items: center;
    gap: 9px;
    text-transform: uppercase;
    background: rgba(7, 12, 110, 0.26);
    border: 1px solid rgba(238, 243, 255, 0.18);
    padding: 9px 12px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06), 0 14px 45px rgba(5, 10, 80, 0.16);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .po-dot {
    width: 7px;
    height: 7px;
    background: var(--c-turquoise);
    display: inline-block;
    border-radius: 50%;
    animation: po-dotpulse 3.2s ease-in-out infinite;
  }
  .po-actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .po-link-read {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(238, 243, 255, 0.66);
    text-decoration: none;
    white-space: nowrap;
    padding: 10px 4px;
    transition: color 0.18s ease;
  }
  .po-link-read:hover {
    color: var(--c-turquoise);
    text-decoration: none;
  }
  .po-menu-btn {
    background: rgba(7, 12, 110, 0.18);
    color: var(--c-on-portal);
    border: 1px solid rgba(238, 243, 255, 0.34);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.13em;
    padding: 10px 13px;
    cursor: pointer;
    text-transform: uppercase;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05), 0 12px 36px rgba(7, 12, 110, 0.18);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .po-cv-btn {
    text-decoration: none;
    background: var(--c-on-portal-2);
    color: var(--c-portal-1);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.13em;
    padding: 11px 15px;
    white-space: nowrap;
    box-shadow: 0 8px 30px rgba(7, 12, 110, 0.28), 0 0 0 1px rgba(238, 243, 255, 0.45);
    text-transform: uppercase;
  }
  .po-cv-btn:hover {
    text-decoration: none;
  }

  /* ---------- INDICE ---------- */
  .po-hint {
    position: absolute;
    top: 78px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 35;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.13em;
    color: var(--c-turquoise);
    background: rgba(7, 12, 110, 0.42);
    border: 1px solid rgba(170, 210, 202, 0.28);
    box-shadow: 0 0 34px rgba(170, 210, 202, 0.1);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    padding: 8px 14px;
    text-transform: uppercase;
    animation: po-hintpulse 2.4s ease-in-out infinite;
    pointer-events: none;
    white-space: nowrap;
  }
  .po-hint[hidden] {
    display: none;
  }

  /* ---------- IDENTITÉ ---------- */
  .po-identity {
    position: absolute;
    left: 26px;
    bottom: 24px;
    z-index: 30;
    max-width: 70vw;
    pointer-events: none;
  }
  .po-name {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: clamp(28px, 3.2vw, 44px);
    line-height: 0.88;
    letter-spacing: -0.045em;
    text-transform: uppercase;
    text-shadow: 0 0 32px rgba(238, 243, 255, 0.12);
  }
  .po-subtitle {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--c-turquoise);
    margin-top: 7px;
    text-transform: uppercase;
  }
  .po-status {
    font-family: var(--font-mono);
    font-size: 10.5px;
    line-height: 1.95;
    letter-spacing: 0.07em;
    color: rgba(234, 240, 255, 0.6);
    margin-top: 13px;
    text-transform: uppercase;
  }
  .po-coords {
    position: absolute;
    right: 26px;
    bottom: 24px;
    z-index: 30;
    text-align: right;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
